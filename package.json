{
  "name": "beansprout-monorepo",
  "version": "0.1.0",
  "description": "Beansprout.ink — monorepo: marketing site (apps/web) + email/form serverless app (apps/functions)",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @beansprout/web",
    "build": "npm run build --workspace @beansprout/web",
    "preview": "npm run preview --workspace @beansprout/web",
    "test": "npm run test --workspaces --if-present",
    "test:web": "npm run test --workspace @beansprout/web",
    "test:functions": "npm run test --workspace @beansprout/functions",
    "test:e2e": "npm run test:e2e --workspace @beansprout/web"
  }
}
