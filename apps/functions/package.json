{
  "name": "@beansprout/functions",
  "version": "0.1.0",
  "description": "Beansprout.ink serverless app — enquiry/flash + newsletter form Worker, deployed to Cloudflare (Workers + D1).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate": "wrangler d1 migrations apply beansprout",
    "migrate:local": "wrangler d1 migrations apply beansprout --local",
    "sync:prices": "node scripts/sync-flash-prices.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "vitest": "^4.1.8",
    "wrangler": "^4.0.0"
  }
}
