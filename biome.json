{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "apps/**/src/**/*.js",
      "apps/**/tests/**/*.js",
      "apps/**/e2e/**/*.js",
      "apps/**/scripts/**/*.mjs",
      "scripts/**/*.mjs",
      "*.js",
      "*.mjs",
      "!**/dist",
      "!**/node_modules",
      "!**/coverage"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "useIterableCallbackReturn": "off"
      },
      "style": {
        "useTemplate": "off"
      },
      "complexity": {
        "useOptionalChain": "off"
      }
    }
  },
  "formatter": { "enabled": false }
}
