# Beansprout — environment template
# Copy to `.env` for local work:  cp .env.example .env
# `.env` is gitignored; never commit real keys.

# ── Site (build-time, baked into the bundle by Vite) ──────────────────────────
# The deployed Netlify function the enquiry + flash-claim forms POST to.
# Get this after creating the Netlify site (Step 2 of ENQUIRY-SETUP.md), then
# rebuild: `npm run build`.
VITE_ENQUIRY_FN_URL=https://beansprout.netlify.app/.netlify/functions/enquiry

# The deployed Netlify function the newsletter signup form POSTs to.
# Created in NEWSLETTER-SETUP.md; rebuild after setting: `npm run build`.
VITE_NEWSLETTER_FN_URL=https://beansprout.netlify.app/.netlify/functions/newsletter

# Read-only endpoint the flash grid calls on load to reflect live availability
# (a piece claimed since the last build). Deploys with the functions workspace —
# no new secrets. Rebuild after setting: `npm run build`.
VITE_FLASH_STATUS_FN_URL=https://beansprout.netlify.app/.netlify/functions/flash-status

# ── Function (server-side) ────────────────────────────────────────────────────
# These are read by the Netlify functions. In production set them in the
# Netlify dashboard (Site configuration → Environment variables) — NOT here.
# Only needed locally if you test the functions with `netlify dev`.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
ARTIST_EMAIL=roxy@beansprout.ink   # destination inbox (where submissions land)
FROM_EMAIL=roxy@beansprout.ink     # sending identity; shown as "Beansprout <roxy@beansprout.ink>"

# Newsletter (read by netlify/functions/newsletter.js):
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # resend.com → Audiences

# ── Abuse limits (optional; the enquiry function uses sane defaults if unset) ──
# Caps successful sends per IP within a window, plus a global daily ceiling that
# protects the Resend quota from a rotating-IP flood. State is stored in Netlify
# Blobs and FAILS OPEN — if Blobs is unavailable, genuine enquiries still go through.
RATE_MAX_PER_IP=5        # max sends per IP per window
RATE_IP_WINDOW_MIN=15    # window length in minutes
RATE_MAX_PER_DAY=80      # global daily send ceiling (Resend free tier = 100/day)
