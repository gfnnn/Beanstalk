# Beansprout — environment template
# Copy to `.env` for local work:  cp .env.example .env
# `.env` is gitignored; never commit real keys.

# ── Site (build-time, baked into the bundle by Vite) ──────────────────────────
# The deployed Cloudflare Worker routes the enquiry + flash-claim + newsletter
# forms POST to. The production defaults are baked into config.js; set these only
# to override (e.g. point at a local `wrangler dev`), then rebuild: `npm run build`.
#   Production:  https://beansprout-forms.harrisonfisher1990.workers.dev/<route>
#   Local dev:   http://localhost:8787/<route>   (from `wrangler dev`)
VITE_ENQUIRY_FN_URL=https://beansprout-forms.harrisonfisher1990.workers.dev/enquiry
VITE_NEWSLETTER_FN_URL=https://beansprout-forms.harrisonfisher1990.workers.dev/newsletter
VITE_FLASH_STATUS_FN_URL=https://beansprout-forms.harrisonfisher1990.workers.dev/flash-status

# ── Worker (server-side) ──────────────────────────────────────────────────────
# These are read by the Cloudflare Worker (apps/functions). In production set them
# with `wrangler secret put <NAME>` or in the Cloudflare dashboard — NOT here.
# Only needed locally if you test the Worker with `wrangler dev` (put them in
# apps/functions/.dev.vars, which is gitignored).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# Where submissions LAND — the inbox the artist actually reads. With the recommended
# setup (docs/EMAIL-DOMAIN-SETUP.md) the @beansprout.ink addresses forward to a
# Gmail account, so this is that Gmail (most reliable — no extra forwarding hop).
# Placeholder only — set the real inbox as a Worker secret, never commit it.
ARTIST_EMAIL=artist@example.com
# Sending identity — must be on the Resend-verified domain. Shown as
# "Beansprout <roxy@beansprout.ink>". Kept different from ARTIST_EMAIL so the
# notification isn't from==to. Use onboarding@resend.dev while testing (it only
# delivers to your own Resend-account email).
FROM_EMAIL=roxy@beansprout.ink

# Newsletter (read by the worker's newsletter route):
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # resend.com → Audiences

# ── Abuse limits (optional; the worker uses sane defaults if unset) ────────────
# Caps successful sends per IP within a window, plus a global daily ceiling that
# protects the Resend quota. State is stored in D1 and FAILS OPEN — if the DB is
# unavailable, genuine enquiries still go through.
RATE_MAX_PER_IP=5        # max sends per IP per window
RATE_IP_WINDOW_MIN=15    # window length in minutes
RATE_MAX_PER_DAY=80      # global daily send ceiling (Resend free tier = 100/day)
